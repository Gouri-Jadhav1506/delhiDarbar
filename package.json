{
  "name": "delhidarbar-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@delhidarbar/web",
    "dev:mobile": "turbo run dev --filter=@delhidarbar/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "rimraf": "^6.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.0"
}
